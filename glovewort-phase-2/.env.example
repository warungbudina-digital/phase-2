# Phase-2 router runtime
ROUTER_PORT=8090
ROUTER_EXEC_TIMEOUT=20
ROUTER_MAX_OUTPUT_CHARS=4000
ROUTER_ALLOW_DOCKER_INSPECT=1
ROUTER_LOG_LEVEL=info

# Upstream phase-1 services
PHASE1_BRIDGE_BASE_URL=http://llm-bridge-api:8000/v1
PHASE1_BRIDGE_API_KEY=
PHASE1_OPENCLAW_GATEWAY_URL=http://openclaw-gateway:18789

# Safety roots
ROUTER_WORKSPACE_ROOT=/workspace
ROUTER_REPO_ROOT=/workspace
ROUTER_WORKSPACE_HOST_PATH=.
PHASE1_FALLBACK_MODEL=qwen2.5-coder:3b-instruct
